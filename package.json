{
  "name": "jetlag",
  "private": true,
  "version": "0.5.13",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "dev": "vite",
    "env:pull": "doppler secrets download --no-file --format env > .env.local",
    "dev:secrets": "doppler run --config dev -- npm run dev",
    "dev:emulator": "doppler run --config dev_emulator -- npm run dev",
    "build:secrets": "doppler run --config prd -- npm run build",
    "build": "tsc -b && vite build && node scripts/delete-dist-sourcemaps.mjs",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:emulator": "firebase emulators:exec --project demo-jetlag --only auth,firestore,storage \"npm run test:emulator:vitest\"",
    "test:emulator:vitest": "vitest run --config vitest.emulator.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "E2E_SMOKE=1 playwright test",
    "test:e2e:visual:update": "firebase emulators:exec --project demo-jetlag --only auth,firestore,storage \"playwright test e2e/visual --grep-invert @manual --update-snapshots\"",
    "test:e2e:ui": "playwright test --ui",
    "capture:tutorial": "firebase emulators:exec --project demo-jetlag --only auth,firestore,storage \"playwright test e2e/visual/tutorial/capture.spec.ts --project=visual\"",
    "audit:overpass": "RUN_OVERPASS_AUDIT=1 vitest run src/services/core/overpassAudit.integration.test.ts",
    "test:functions": "env -u npm_config_allow_scripts sh -c 'cd functions && npm ci && npm test'",
    "test:unit": "vitest run && npm test --prefix functions",
    "test:ci": "npm run test:coverage && npm run test:functions",
    "test:perf": "GEOMETRY_PERF=1 vitest run src/domain/geometry/geometryPerf.test.ts --pool=forks --maxWorkers=1",
    "test:changed": "vitest run --changed origin/main --passWithNoTests",
    "emulators:start": "firebase emulators:start --project demo-jetlag --only auth,firestore,storage,functions",
    "deploy": "node scripts/deploy-production.mjs",
    "deploy:worker": "npm run build && wrangler deploy",
    "preview:worker": "npm run build && wrangler dev",
    "cf-typegen": "wrangler types",
    "changeset": "changeset",
    "version": "changeset version && node scripts/sync-changelog-ts.mjs",
    "release:sync": "node scripts/sync-changelog-ts.mjs && node scripts/release-check.mjs",
    "release:check": "node scripts/release-check.mjs",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/push-notifications": "^8.1.1",
    "@fontsource/barlow-semi-condensed": "^5.2.7",
    "@fontsource/source-sans-3": "^5.2.9",
    "@sentry/capacitor": "^4.2.0",
    "@sentry/react": "10.60.0",
    "@tmcw/togeojson": "^7.1.2",
    "@turf/area": "^7.3.5",
    "@turf/bbox": "^7.3.5",
    "@turf/bbox-polygon": "^7.3.5",
    "@turf/boolean-intersects": "^7.3.5",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/buffer": "^7.3.5",
    "@turf/circle": "^7.3.5",
    "@turf/difference": "^7.3.5",
    "@turf/distance": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@turf/intersect": "^7.3.5",
    "@turf/length": "^7.3.5",
    "@turf/nearest-point-on-line": "^7.3.5",
    "@turf/polygonize": "^7.3.5",
    "@turf/projection": "^7.3.5",
    "@turf/simplify": "^7.3.5",
    "@turf/union": "^7.3.5",
    "circle-union": "^1.0.0",
    "comlink": "^4.4.2",
    "d3-geo": "^3.1.1",
    "d3-geo-projection": "^4.0.0",
    "d3-geo-voronoi": "^2.1.0",
    "date-fns": "^4.4.0",
    "firebase": "^12.13.0",
    "flatbush": "^4.6.2",
    "geoflatbush": "^2.2.1",
    "geokdbush": "^2.1.0",
    "html2canvas": "^1.4.1",
    "jetlag-live-activity": "file:plugins/jetlag-live-activity",
    "jszip": "^3.10.1",
    "kdbush": "^4.1.0",
    "leaflet": "^1.9.4",
    "lru-cache": "^11.5.2",
    "martinez-polygon-clipping": "^0.8.1",
    "rbush": "^4.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.15.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@cloudflare/workers-types": "^5.20260712.1",
    "@commitlint/cli": "~21.2.1",
    "@commitlint/config-conventional": "~21.2.0",
    "@eslint/js": "~10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/vite": "~4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-geo": "^3.1.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.3",
    "@types/rbush": "^4.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "~6.0.1",
    "@vitest/coverage-v8": "~4.1.9",
    "eslint": "~10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "firebase-tools": "^15.23.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "~29.1.1",
    "tailwindcss": "~4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "~8.59.2",
    "vite": "~8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "~4.1.6",
    "wrangler": "^4.110.0"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "1.0.3",
    "@rolldown/binding-darwin-x64": "1.0.3",
    "@rolldown/binding-linux-x64-gnu": "1.0.3"
  },
  "overrides": {
    "node-fetch": {
      "whatwg-url": "^14.0.0"
    },
    "uuid": "^11.1.1",
    "@opentelemetry/core": "^2.8.0"
  },
  "allowScripts": {
    "@firebase/util@1.15.1": true,
    "@sentry/capacitor@4.2.0": true,
    "@sentry/cli@2.58.6": true,
    "esbuild@0.28.1": true,
    "protobufjs@7.5.8": true,
    "protobufjs@7.6.5": true,
    "re2@1.25.1": true,
    "sharp@0.34.5": true,
    "workerd@1.20260708.1": true
  }
}
