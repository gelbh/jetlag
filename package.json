{
  "name": "jetlag",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:emulator": "firebase emulators:exec --only auth,firestore,storage \"npm run test:emulator:vitest\"",
    "test:emulator:vitest": "vitest run --config vitest.emulator.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "E2E_SMOKE=1 playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit:overpass": "RUN_OVERPASS_AUDIT=1 vitest run src/services/core/overpassAudit.integration.test.ts",
    "test:functions": "npm test --prefix functions",
    "test:unit": "vitest run && npm test --prefix functions",
    "test:ci": "npm run test:coverage && npm run test:functions",
    "emulators:start": "firebase emulators:start --only auth,firestore,storage",
    "deploy": "node scripts/deploy-production.mjs",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/push-notifications": "^8.1.1",
    "@fontsource/barlow-semi-condensed": "^5.2.7",
    "@fontsource/source-sans-3": "^5.2.9",
    "@tmcw/togeojson": "^7.1.2",
    "@turf/area": "^7.3.5",
    "@turf/bbox-polygon": "^7.3.5",
    "@turf/boolean-intersects": "^7.3.5",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/buffer": "^7.3.5",
    "@turf/circle": "^7.3.5",
    "@turf/difference": "^7.3.5",
    "@turf/distance": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@turf/intersect": "^7.3.5",
    "@turf/length": "^7.3.5",
    "@turf/nearest-point-on-line": "^7.3.5",
    "@turf/polygonize": "^7.3.5",
    "@turf/projection": "^7.3.5",
    "@turf/simplify": "^7.3.5",
    "@turf/union": "^7.3.5",
    "@turf/voronoi": "^7.3.5",
    "d3-geo": "^3.1.1",
    "d3-geo-projection": "^4.0.0",
    "d3-geo-voronoi": "^2.1.0",
    "firebase": "^12.13.0",
    "html2canvas": "^1.4.1",
    "jetlag-live-activity": "file:plugins/jetlag-live-activity",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.15.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@commitlint/cli": "~21.2.0",
    "@commitlint/config-conventional": "~21.2.0",
    "@eslint/js": "~10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "~4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-geo": "^3.1.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "~6.0.1",
    "@vitest/coverage-v8": "~4.1.9",
    "eslint": "~10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "firebase-tools": "^15.18.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "~29.1.1",
    "tailwindcss": "~4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "~8.59.2",
    "vite": "~8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "~4.1.6"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "1.0.3",
    "@rolldown/binding-darwin-x64": "1.0.3",
    "@rolldown/binding-linux-x64-gnu": "1.0.3"
  },
  "overrides": {
    "node-fetch": {
      "whatwg-url": "^14.0.0"
    }
  }
}
