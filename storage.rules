rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function sessionData(sessionId) {
      return firestore.get(/databases/(default)/documents/sessions/$(sessionId)).data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isSessionMember(sessionId) {
      return isSignedIn()
        && request.auth.uid in sessionData(sessionId).memberUids;
    }

    function isLegacySession(sessionId) {
      return !('memberRoles' in sessionData(sessionId))
        || sessionData(sessionId).memberRoles == null;
    }

    function memberRole(sessionId) {
      return sessionData(sessionId).memberRoles[request.auth.uid];
    }

    function isSeekerMember(sessionId) {
      return isSessionMember(sessionId)
        && (isLegacySession(sessionId) || memberRole(sessionId) == 'seeker');
    }

    function isHiderMember(sessionId) {
      return isSessionMember(sessionId)
        && !isLegacySession(sessionId)
        && memberRole(sessionId) == 'hider';
    }

    match /sessions/{sessionId}/photoAnswers/{questionId}/{fileName} {
      allow read: if isSessionMember(sessionId);
      allow write: if isHiderMember(sessionId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
