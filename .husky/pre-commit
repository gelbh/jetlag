#!/usr/bin/env bash
# Husky invokes hooks with `sh`; re-exec under bash for pipefail / local.
if [ -z "${BASH_VERSION:-}" ]; then
  exec bash "$0" "$@"
fi
set -euo pipefail

css="$(mktemp)"
related="$(mktemp)"
staged="$(mktemp)"
trap 'rm -f "$css" "$related" "$staged"' EXIT

if ! git diff --cached --name-only -z --diff-filter=ACMR >"$staged"; then
  exit 1
fi

if [ ! -s "$staged" ]; then
  exit 0
fi

# Ban agent-local project-dir path strings in tracked blobs (see agent-local-only skill).
# Pattern built at runtime so this hook file does not contain the banned substring.
agent_dir_slash="$(printf '.%s/' 'cursor')"
while IFS= read -r -d '' path; do
  case "$path" in
    .husky/*) continue ;;
  esac
  if git show ":$path" 2>/dev/null | grep -F -n -- "$agent_dir_slash" >/dev/null; then
    echo "pre-commit: '$path' mentions ${agent_dir_slash} — agent-local only; remove before commit" >&2
    git show ":$path" 2>/dev/null | grep -F -n -- "$agent_dir_slash" >&2 || true
    exit 1
  fi
done <"$staged"

while IFS= read -r -d '' path; do
  case "$path" in
    *.css)
      printf '%s\0' "$path" >>"$css"
      ;;
    src/*.ts | src/*.tsx)
      printf '%s\0' "$path" >>"$related"
      ;;
  esac
done <"$staged"

# Reject partial staging: tools read the working tree, so unstaged
# edits on selected paths would mask or falsely fail the commit snapshot.
reject_partial() {
  local list="$1"
  [ -s "$list" ] || return 0
  while IFS= read -r -d '' path; do
    local unstaged
    if ! unstaged="$(git diff --name-only -- "$path")"; then
      echo "pre-commit: failed to inspect unstaged changes for '$path'" >&2
      exit 1
    fi
    if [ -n "$unstaged" ]; then
      echo "pre-commit: '$path' has unstaged changes; stage or stash them before commit" >&2
      exit 1
    fi
  done <"$list"
}

reject_partial "$css"
reject_partial "$related"

if [ -s "$css" ]; then
  xargs -0 npx stylelint -- <"$css"
fi

if [ ! -s "$related" ]; then
  exit 0
fi

xargs -0 npx vitest related --run --passWithNoTests -- <"$related"
