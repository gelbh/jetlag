#!/usr/bin/env sh
set -e

# NUL-delimited paths stay filename-safe (spaces / glob chars).
css="$(mktemp)"
related="$(mktemp)"
trap 'rm -f "$css" "$related"' EXIT

git diff --cached --name-only -z --diff-filter=ACM |
  while IFS= read -r -d '' path; do
    case "$path" in
      *.css)
        printf '%s\0' "$path" >>"$css"
        ;;
      src/*.ts | src/*.tsx)
        printf '%s\0' "$path" >>"$related"
        ;;
    esac
  done

if [ -s "$css" ]; then
  xargs -0 -r npx stylelint <"$css"
fi

if [ ! -s "$related" ]; then
  exit 0
fi

xargs -0 -r npx vitest related --run --passWithNoTests <"$related"
