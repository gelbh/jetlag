#!/usr/bin/env sh
set -e

staged="$(git diff --cached --name-only --diff-filter=ACM)"

if [ -z "$staged" ]; then
  exit 0
fi

css=""
related=""
for path in $staged; do
  case "$path" in
    *.css)
      css="$css $path"
      ;;
    src/*.ts|src/*.tsx)
      related="$related $path"
      ;;
  esac
done

if [ -n "$css" ]; then
  # shellcheck disable=SC2086
  npx stylelint $css
fi

if [ -z "$related" ]; then
  exit 0
fi

# shellcheck disable=SC2086
npx vitest related --run --passWithNoTests $related
