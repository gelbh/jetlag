# Set these `VITE_*` vars in Cloudflare Pages for production builds.

# -----------------------------------------------------------------------------
# Firebase (multi-device sync)
# Required for shared sessions and annotation sync.
# From Firebase Console → Project settings → Your apps → Web app config.
# -----------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional. reCAPTCHA v3 site key for Firebase App Check (abuse resistance on functions).
# Create in Firebase Console → App Check.
VITE_FIREBASE_APP_CHECK_SITE_KEY=

# -----------------------------------------------------------------------------
# Premium session proxies (Firebase Cloud Functions — Blaze plan)
# Used only when the host creates a Premium session. Free sessions use public APIs.
# After `npm run deploy`, copy the printed URLs into Cloudflare Pages.
# -----------------------------------------------------------------------------

# Overpass geographic data (caching, failover).
VITE_OVERPASS_PROXY_URL=

# Live London vehicles (TfL feed).
VITE_TRANSIT_PROXY_URL=

# Live vehicles for other metros (Transitland). API key stays server-side only.
VITE_TRANSITLAND_PROXY_URL=

# -----------------------------------------------------------------------------
# Firebase Functions secrets (set via CLI — never put in VITE_* or commit)
# firebase functions:secrets:set ACCESS_CODE
# firebase functions:secrets:set TRANSITLAND_API_KEY
# -----------------------------------------------------------------------------

# Optional. Error reporting when VITE_SENTRY_DSN is set (Cloudflare Pages env).
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production

# -----------------------------------------------------------------------------
# Deploy script only (not read by the app)
# Set to 0/false/no/off to skip Cloud Functions during `npm run deploy`.
# -----------------------------------------------------------------------------
DEPLOY_FIREBASE_FUNCTIONS=
