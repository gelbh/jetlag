# Firebase (multi-device sync)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# reCAPTCHA v3 site key for Firebase App Check
VITE_FIREBASE_APP_CHECK_SITE_KEY=

# Local App Check debug token (emulator / dev only)
VITE_FIREBASE_APP_CHECK_DEBUG_TOKEN=

# Use Firebase emulators (auth, firestore, storage)
VITE_USE_FIREBASE_EMULATOR=false

# Overpass geographic data (caching, failover)
VITE_OVERPASS_PROXY_URL=

# Live London vehicles (TfL feed)
VITE_TRANSIT_PROXY_URL=

# Live vehicles for other metros (Transitland)
VITE_TRANSITLAND_PROXY_URL=

# Sentry (optional locally; required in production CI)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
# Set in CI only — git commit SHA for release correlation
# VITE_SENTRY_RELEASE_DIST=

# Google Analytics (optional)
VITE_GA_MEASUREMENT_ID=

# CI production build only — upload source maps to Sentry (never commit)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
