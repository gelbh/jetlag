# Copy to `.env.local` for local dev. Set the same `VITE_*` vars in Cloudflare Pages for production.
# Restart the dev server after any change.

# -----------------------------------------------------------------------------
# Firebase (multi-device sync)
# Required for shared sessions and annotation sync. Omit to run local-only.
# From Firebase Console → Project settings → Your apps → Web app config.
# -----------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# -----------------------------------------------------------------------------
# Transit overlays
# Optional. Static route lines work with Transitland alone; live vehicles need
# one of the two options below.
# -----------------------------------------------------------------------------

# Live vehicle positions via Firebase `vehicles` function (requires Blaze plan).
# After `npm run deploy`, copy the printed URL or find it in Firebase Console → Functions.
VITE_TRANSIT_PROXY_URL=

# Static transit data and live vehicles (fallback when no proxy).
# Create a key at https://app.interline.io/
VITE_TRANSITLAND_API_KEY=

# -----------------------------------------------------------------------------
# Geographic API proxies
# Recommended. Routes Overpass through Firebase with server-side cache (1 h) and failover.
# Requires Blaze plan (pay-as-you-go — free tier covers infrequent use).
# 1. Upgrade Firebase to Blaze  2. `npm run deploy`  3. paste the printed URL here and in Cloudflare Pages.
# -----------------------------------------------------------------------------
VITE_OVERPASS_PROXY_URL=

# -----------------------------------------------------------------------------
# Deploy script only (not read by the app)
# Set to 0/false/no/off to skip Cloud Functions during `npm run deploy`.
# -----------------------------------------------------------------------------
DEPLOY_FIREBASE_FUNCTIONS=
